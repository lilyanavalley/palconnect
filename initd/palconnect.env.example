# PalConnect Environment Configuration
# Copy this file to /etc/palconnect/palconnect.env and configure your settings

# Discord Bot Token (Required)
DISCORD_TOKEN=your_discord_bot_token_here

# PalWorld Server Configuration
PALWORLD_API_URL=http://localhost:8212
PALWORLD_ADMIN_PASSWORD=your_palworld_admin_password_here

# Auto-update Configuration
UPDATES_AUTO_ENABLE=false

# Logging Configuration
RUST_LOG=info

# Health Check Port (default: 3000)
# PALCONNECT_HEALTH_PORT=3000

# OS service manager used to start/stop the PalWorld server (default: systemd)
# Set to "initd" when running on a system without systemd.
# Supported values: systemd, initd, none
PALWORLD_SERVICE_MANAGER=initd

# Name of the PalWorld init.d service script (default: palworld)
# Must match the filename under /etc/init.d (e.g. "palworld" → /etc/init.d/palworld)
PALWORLD_SERVICE_NAME=palworld
