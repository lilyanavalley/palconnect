# Discord Bot Token - Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# PalWorld Dedicated Server REST API URL
# Default: http://localhost:8212 (if running locally)
# Replace with your server's IP and port if running remotely
PALWORLD_API_URL=http://localhost:8212

# PalWorld Server Admin Password (set in your server config as AdminPassword)
# This is used for REST API authentication (username is always "admin")
PALWORLD_ADMIN_PASSWORD=your_admin_password_here

# Enable auto updating? (true/false)
# If true, the bot will check for updates on startup and apply them automatically
# If false, the bot will not check for updates automatically (default)
UPDATES_AUTO_ENABLE=false

# Status update interval in seconds (default: 30)
# How often the bot polls the PalWorld server and updates its Discord activity status
# with the current player count. Minimum recommended: 15 seconds
STATUS_UPDATE_INTERVAL=30

# OS service manager used to start/stop the PalWorld server (default: systemd)
# Supported values: systemd, initd, none
#   systemd — uses `systemctl` (Linux with systemd)
#   initd   — uses `/etc/init.d/<name>` (SysV init / Linux without systemd)
#   none    — no OS service control; /start and /forcestop use the REST API only
PALWORLD_SERVICE_MANAGER=systemd

# Name of the PalWorld OS service unit (default: palworld)
# For systemd this is typically "palworld" or "palworld.service".
# For init.d this is the script name under /etc/init.d (e.g. "palworld").
PALWORLD_SERVICE_NAME=palworld
