# PalConnect Environment Configuration
# Copy this file to /etc/palconnect/palconnect.env and configure your settings

# Discord Bot Token (Required)
DISCORD_TOKEN=your_discord_bot_token_here

# PalWorld Server Configuration
PALWORLD_API_URL=http://localhost:8212
PALWORLD_ADMIN_PASSWORD=your_palworld_admin_password_here

# Auto-update Configuration
UPDATES_AUTO_ENABLE=false

# Logging Configuration
RUST_LOG=info

# Health Check Port (default: 3000)
# PALCONNECT_HEALTH_PORT=3000
